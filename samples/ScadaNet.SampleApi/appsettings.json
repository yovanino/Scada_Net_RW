{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ScadaNet": {
    "Devices": [
      {
        "Name": "line1-plc",
        "Driver": "logix",
        "Address": "192.168.0.10",
        "Port": 44818,
        "Path": "1,0",
        "Timeout": "00:00:02",
        "WritesEnabled": true,
        "WritableAddresses": [
          "ResetCommand",
          "Recipe.Values"
        ],
        "Signals": [
          {
            "Name": "production-counter",
            "Address": "ProductionCounter",
            "DataType": "DINT",
            "Unit": "parts",
            "Description": "Good parts counter"
          },
          {
            "Name": "motor-speed",
            "Address": "Motor.Speed",
            "DataType": "REAL",
            "Unit": "rpm",
            "Description": "Main motor speed"
          },
          {
            "Name": "speed-history",
            "Address": "Motor.SpeedHistory",
            "DataType": "REAL",
            "Unit": "rpm",
            "Description": "Recent motor speed samples",
            "IsArray": true,
            "ElementCount": 10
          },
          {
            "Name": "recipe-values",
            "Address": "Recipe.Values",
            "DataType": "REAL",
            "Description": "Active recipe values",
            "IsArray": true,
            "ElementCount": 3,
            "Writable": true
          },
          {
            "Name": "reset-command",
            "Address": "ResetCommand",
            "DataType": "BOOL",
            "Description": "Production counter reset command",
            "Writable": true
          }
        ]
      }
    ],
    "PollingGroups": [
      {
        "Name": "line1-fast",
        "DeviceName": "line1-plc",
        "Interval": "00:00:01",
        "Addresses": [
          "ProductionCounter",
          "Motor.Speed"
        ],
        "SignalNames": [
          "production-counter",
          "motor-speed"
        ]
      }
    ]
  },
  "AllowedHosts": "*"
}
